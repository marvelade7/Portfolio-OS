{
  "name": "ubuntu-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Ubuntu 22.04 GNOME themed developer portfolio monorepo.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "preview": "npm run preview --workspace client",
    "start": "npm run start --workspace server",
    "seed": "npm run seed --workspace server",
    "asset:wallpaper": "node scripts/generate-wallpaper.mjs"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
